{
  "name": "oliveseed",
  "version": "0.0.2",
  "scripts": {
    "start": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "install:dep": "npm install axios shut --save",
    "install:dev": "npm install @sveltejs/adapter-auto @sveltejs/adapter-static @sveltejs/package @sveltejs/vite-plugin-svelte @types/node autoprefixer globals postcss svelte-check typescript vite @sveltejs/kit svelte just-clone lodash.merge --save-dev",
    "install:all": "npm run install:dep && npm run install:dev"
  },
  "type": "module",
  "dependencies": {
    "axios": "^1.15.2",
    "shut": "^7.1.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "globals": "^17.5.0",
    "just-clone": "^6.2.0",
    "lodash.merge": "^4.6.2",
    "postcss": "^8.5.10",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  }
}
